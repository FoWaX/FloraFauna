<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Second_try" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/app_background</item>
        <item name="android:textColor">@color/app_text_dark</item>
        <item name="colorPrimary">@color/app_primary_green</item>
        <item name="colorPrimaryDark">@color/app_dark_green</item>
        <item name="colorAccent">@color/app_coral</item>
        <item name="buttonStyle">@style/AppButtonStyle</item>
    </style>

    <style name="AppButtonStyle" parent="Widget.AppCompat.Button">
        <item name="android:backgroundTint">@color/app_primary_green</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
